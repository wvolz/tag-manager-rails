<%= form_with(model: api_key, local: true, class: "w-full") do |form| %>
  <% if api_key.errors.any? %>
    <div class="alert alert-error shadow-sm mb-4">
      <ul class="list-disc list-inside text-sm">
        <% api_key.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-control mb-3">
    <%= form.label :bearer, "Associated With", class: "label" %>
    <% bearer_options = [["Myself (#{current_user.email})", "User_#{current_user.id}"]] %>
    <% if current_user.admin? && current_authorizer_app.present? %>
      <% bearer_options << ["Authorizer App: #{current_authorizer_app.name}", "AuthorizerApp_#{current_authorizer_app.id}"] %>
    <% end %>
    <%= form.select :bearer_string,
          options_for_select(bearer_options, api_key.bearer ? "#{api_key.bearer_type}_#{api_key.bearer_id}" : api_key.bearer_string || "User_#{current_user.id}"),
          {},
          class: "select select-bordered w-full" %>
  </div>

  <div class="form-control mb-3">
    <%= form.label :comment, "Comment / Description", class: "label" %>
    <%= form.text_field :comment, class: "input input-bordered w-full", placeholder: "e.g. Reader at front entrance" %>
  </div>

  <p class="text-xs text-base-content/60 mb-4">Token is shown once after creation.</p>

  <div class="mt-4">
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
