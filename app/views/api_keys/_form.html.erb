<%= form_with(model: api_key, local: true) do |form| %>
  <% if api_key.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(api_key.errors.count, "error") %> prohibited this API Key from being saved:</h2>

      <ul>
      <% api_key.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mt-1">
    <%= form.label :bearer, "Associated With", class: "label" %>
    <%= form.select :bearer_string, 
          options_for_select(
            [["Myself (#{current_user.email})", "User_#{current_user.id}"]] + 
            Reader.all.map { |r| ["Reader: #{r.name}", "Reader_#{r.id}"] },
            api_key.bearer ? "#{api_key.bearer_type}_#{api_key.bearer_id}" : nil
          ), 
          {}, 
          class: "select select-bordered w-full max-w-xs" %>
  </div>

  <div class="mt-1">
    <%= form.label :comment, "Comment / Description", class:"label" %>
    <%= form.text_field :comment, class:"input input-bordered w-full max-w-xs" %>
  </div>

  <div class="mt-1">
    <%= form.submit class:"btn btn-primary" %>
  </div>
<% end %>
