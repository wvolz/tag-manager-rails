<%= form_with(model: authorization, local: true, class: "w-full max-w-md") do |form| %>
  <% if authorization.errors.any? %>
    <div class="alert alert-error shadow-sm mb-4">
      <ul class="list-disc list-inside text-sm">
        <% authorization.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-control mb-3">
    <%= form.label :name, class: "label" %>
    <%= form.text_field :name, id: :authorization_name, class: "input input-bordered w-full" %>
  </div>

  <div class="mt-4">
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
