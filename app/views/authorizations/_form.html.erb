<%= form_with(model: authorization, local: true) do |form| %>
  <% render "shared/form_card",
      title: authorization.new_record? ? "New Authorization" : "Edit Authorization",
      model: authorization,
      form: form,
      back_path: authorizations_path,
      submit_label: authorization.new_record? ? "Create Authorization" : "Update Authorization" do %>

    <div class="form-control">
      <%= form.label :name, "Name", class: "label" %>
      <%= form.text_field :name,
          id: :authorization_name,
          class: "input input-bordered w-full",
          placeholder: "e.g. Building A Access",
          required: true %>
    </div>

  <% end %>
<% end %>
