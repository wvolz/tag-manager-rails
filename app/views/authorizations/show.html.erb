<% content_for :title, @authorization.name %>

<%= render "shared/show_header",
    title: @authorization.name,
    subtitle: "Authorization Group",
    back_path: authorizations_path %>

<div class="max-w-xl">
  <div class="card bg-base-100 shadow-sm border border-base-200">
    <div class="card-body">
      <table class="table table-sm">
        <tbody>
          <tr>
            <th class="w-32 text-base-content/60 font-medium">Name</th>
            <td><%= @authorization.name %></td>
          </tr>
          <tr>
            <th class="text-base-content/60 font-medium">Created</th>
            <td><time datetime="<%= @authorization.created_at.iso8601 %>"><%= @authorization.created_at.strftime("%b %d, %Y") %></time></td>
          </tr>
        </tbody>
      </table>

      <div class="card-actions justify-end mt-4">
        <%= link_to "Edit", edit_authorization_path(@authorization), class: "btn btn-outline btn-sm" %>
        <%= link_to "Delete", authorization_path(@authorization),
            data: { turbo_method: :delete, turbo_confirm: "Delete this authorization?" },
            class: "btn btn-error btn-outline btn-sm" %>
      </div>
    </div>
  </div>
</div>
