<%= form_with(model: reader, local: true) do |form| %>
  <% render "shared/form_card",
      title: reader.new_record? ? "New Reader" : "Edit Reader",
      model: reader,
      form: form,
      back_path: readers_path,
      submit_label: reader.new_record? ? "Create Reader" : "Update Reader" do %>

    <div class="form-control">
      <%= form.label :name, "Name", class: "label" %>
      <%= form.text_field :name,
          class: "input input-bordered w-full",
          placeholder: "e.g. Front Door Reader",
          required: true %>
    </div>

    <div class="form-control">
      <%= form.label :location, "Location", class: "label" %>
      <%= form.text_field :location,
          class: "input input-bordered w-full",
          placeholder: "e.g. Building A, Floor 3" %>
    </div>

  <% end %>
<% end %>
