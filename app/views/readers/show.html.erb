<% content_for :title, @reader.name %>

<%= render "shared/show_header",
    title: @reader.name,
    subtitle: "RFID Reader",
    back_path: readers_path %>

<div class="max-w-3xl space-y-4">
  <div class="card bg-base-100 shadow-sm border border-base-200">
    <div class="card-body">
      <table class="table table-sm">
        <tbody>
          <tr>
            <th class="w-32 text-base-content/60 font-medium">Name</th>
            <td><%= @reader.name %></td>
          </tr>
          <tr>
            <th class="text-base-content/60 font-medium">Location</th>
            <td><%= @reader.location.presence || "—" %></td>
          </tr>
          <tr>
            <th class="text-base-content/60 font-medium">MAC Address</th>
            <td class="font-mono text-xs"><%= @reader.mac_address.presence || "—" %></td>
          </tr>
          <tr>
            <th class="text-base-content/60 font-medium">Reader Name</th>
            <td><%= @reader.reader_name.presence || "—" %></td>
          </tr>
          <tr>
            <th class="text-base-content/60 font-medium">Hostname</th>
            <td><%= @reader.hostname.presence || "—" %></td>
          </tr>
          <tr>
            <th class="text-base-content/60 font-medium">Source IP</th>
            <td class="font-mono text-xs"><%= @reader.source_ip.presence || "—" %></td>
          </tr>
          <tr>
            <th class="text-base-content/60 font-medium">Last Seen</th>
            <td><%= @reader.last_seen_at ? local_time(@reader.last_seen_at) : "—" %></td>
          </tr>
          <tr>
            <th class="text-base-content/60 font-medium">Created</th>
            <td><time datetime="<%= @reader.created_at.iso8601 %>"><%= @reader.created_at.strftime("%b %d, %Y") %></time></td>
          </tr>
        </tbody>
      </table>

      <div class="card-actions justify-end mt-4">
        <%= link_to "Edit", edit_reader_path(@reader), class: "btn btn-outline btn-sm" %>
        <%= link_to "Delete", reader_path(@reader),
            data: { turbo_method: :delete, turbo_confirm: "Delete this reader?" },
            class: "btn btn-error btn-outline btn-sm" %>
      </div>
    </div>
  </div>

  <div class="card bg-base-100 shadow-sm border border-base-200">
    <div class="card-body">
      <h2 class="card-title text-lg mb-2">Antenna Authorization Mapping</h2>

      <% if @reader.reader_antennas.exists? %>
        <div class="overflow-x-auto">
          <table class="table table-sm table-zebra">
            <thead>
              <tr>
                <th>Antenna</th>
                <th>Authorization</th>
              </tr>
            </thead>
            <tbody>
              <% @reader.reader_antennas.order(:antenna).each do |reader_antenna| %>
                <tr>
                  <td><%= reader_antenna.antenna %></td>
                  <td><%= reader_antenna.authorization&.name || "Capture only (record_only)" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-sm text-base-content/50 py-4 text-center">No antenna mappings yet.</p>
      <% end %>
    </div>
  </div>
</div>
