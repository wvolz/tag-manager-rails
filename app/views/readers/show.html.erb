<% content_for :title, @reader.name %>

<%= render "shared/show_header",
    title: @reader.name,
    subtitle: "RFID Reader",
    back_path: readers_path %>

<div class="max-w-3xl space-y-4">
  <div class="card bg-base-100 shadow-sm border border-base-200">
    <div class="card-body">
      <table class="table table-sm">
        <tbody>
          <tr>
            <th class="w-32 text-base-content/60 font-medium">Name</th>
            <td><%= @reader.name %></td>
          </tr>
          <tr>
            <th class="text-base-content/60 font-medium">Location</th>
            <td><%= @reader.location.presence || "—" %></td>
          </tr>
          <tr>
            <th class="text-base-content/60 font-medium">Created</th>
            <td><time datetime="<%= @reader.created_at.iso8601 %>"><%= @reader.created_at.strftime("%b %d, %Y") %></time></td>
          </tr>
        </tbody>
      </table>

      <div class="card-actions justify-end mt-4">
        <%= link_to "Edit", edit_reader_path(@reader), class: "btn btn-outline btn-sm" %>
        <%= link_to "Delete", reader_path(@reader),
            data: { turbo_method: :delete, turbo_confirm: "Delete this reader and all its API keys?" },
            class: "btn btn-error btn-outline btn-sm" %>
      </div>
    </div>
  </div>

  <div class="card bg-base-100 shadow-sm border border-base-200">
    <div class="card-body">
      <div class="flex items-center justify-between mb-2">
        <h2 class="card-title text-lg">API Keys</h2>
        <%= link_to "New API Key", new_api_key_path(bearer_id: @reader.id, bearer_type: "Reader"),
            class: "btn btn-primary btn-xs" %>
      </div>

      <% if @reader.api_keys.exists? %>
        <div class="overflow-x-auto">
          <table class="table table-sm table-zebra">
            <thead>
              <tr>
                <th>ID</th>
                <th>Comment</th>
                <th>Created</th>
              </tr>
            </thead>
            <tbody>
              <% @reader.api_keys.each do |api_key| %>
                <tr>
                  <td class="font-mono text-xs"><%= api_key.id %></td>
                  <td><%= api_key.comment.presence || "—" %></td>
                  <td><time datetime="<%= api_key.created_at.iso8601 %>"><%= api_key.created_at.strftime("%b %d, %Y") %></time></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-sm text-base-content/50 py-4 text-center">No API keys yet.</p>
      <% end %>
    </div>
  </div>
</div>
