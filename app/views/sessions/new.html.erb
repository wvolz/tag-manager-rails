<% content_for :title, "Sign In" %>

<div class="min-h-[70vh] flex items-center justify-center">
  <div class="card w-full max-w-sm bg-base-200 shadow-lg">
    <div class="card-body">
      <div class="text-center mb-4">
        <h1 class="text-2xl font-bold">TagManager</h1>
        <p class="text-sm text-base-content/60 mt-1">Sign in to your account</p>
      </div>

      <%= form_for :session, url: session_path do |form| %>
        <div class="form-control mb-3">
          <%= form.label :email, class: "label label-text font-medium" %>
          <%= form.email_field :email, class: "input input-bordered w-full", placeholder: "you@example.com", autofocus: true %>
        </div>

        <div class="form-control mb-5">
          <%= form.label :password, class: "label label-text font-medium" %>
          <%= form.password_field :password, class: "input input-bordered w-full", placeholder: "••••••••" %>
        </div>

        <div class="form-control">
          <%= form.submit "Sign In", class: "btn btn-primary w-full" %>
        </div>

        <div class="text-center mt-4 text-sm text-base-content/60">
          <% if Clearance.configuration.allow_sign_up? %>
            <%= link_to "Create an account", sign_up_path, class: "link" %> &bull;
          <% end %>
          <%= link_to "Forgot password?", new_password_path, class: "link" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
