<% content_for :title, "Settings" %>

<div class="max-w-3xl space-y-6">
  <div>
    <h1 class="text-2xl font-bold">Settings</h1>
    <p class="mt-1 text-sm text-base-content/60">App version: <span class="font-mono"><%= app_version_label %></span></p>
  </div>

  <div class="card bg-base-100 border border-base-300 shadow-sm">
    <div class="card-body space-y-4">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h2 class="card-title text-lg">Job Queue</h2>
          <p class="text-sm text-base-content/60">Current Solid Queue backlog, worker heartbeat, and recent failures.</p>
        </div>
        <div class="badge <%= @queue_status[:available] ? "badge-success" : "badge-warning" %> badge-outline">
          <%= @queue_status[:available] ? "Available" : "Unavailable" %>
        </div>
      </div>

      <% if @queue_status[:available] %>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
          <div class="rounded-box border border-base-300 p-3">
            <div class="text-xs uppercase tracking-wide text-base-content/60">Ready</div>
            <div class="text-2xl font-semibold"><%= @queue_status.dig(:totals, :ready) %></div>
          </div>
          <div class="rounded-box border border-base-300 p-3">
            <div class="text-xs uppercase tracking-wide text-base-content/60">Scheduled</div>
            <div class="text-2xl font-semibold"><%= @queue_status.dig(:totals, :scheduled) %></div>
          </div>
          <div class="rounded-box border border-base-300 p-3">
            <div class="text-xs uppercase tracking-wide text-base-content/60">Running</div>
            <div class="text-2xl font-semibold"><%= @queue_status.dig(:totals, :running) %></div>
          </div>
          <div class="rounded-box border border-base-300 p-3">
            <div class="text-xs uppercase tracking-wide text-base-content/60">Failed</div>
            <div class="text-2xl font-semibold"><%= @queue_status.dig(:totals, :failed) %></div>
          </div>
          <div class="rounded-box border border-base-300 p-3">
            <div class="text-xs uppercase tracking-wide text-base-content/60">Blocked</div>
            <div class="text-2xl font-semibold"><%= @queue_status.dig(:totals, :blocked) %></div>
          </div>
        </div>

        <div class="grid gap-4 lg:grid-cols-2">
          <div>
            <h3 class="font-medium mb-2">Workers</h3>
            <div class="overflow-x-auto">
              <table class="table table-sm">
                <tbody>
                  <tr>
                    <th>Live</th>
                    <td><%= @queue_status.dig(:workers, :live) %></td>
                  </tr>
                  <tr>
                    <th>Stale</th>
                    <td><%= @queue_status.dig(:workers, :stale) %></td>
                  </tr>
                  <tr>
                    <th>Total</th>
                    <td><%= @queue_status.dig(:workers, :total) %></td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <div>
            <h3 class="font-medium mb-2">Active Queues</h3>
            <% if @queue_status[:queues].any? %>
              <div class="overflow-x-auto">
                <table class="table table-sm">
                  <thead>
                    <tr>
                      <th>Queue</th>
                      <th class="text-right">Jobs</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% @queue_status[:queues].each do |queue_name, count| %>
                      <tr>
                        <td><%= queue_name %></td>
                        <td class="text-right"><%= count %></td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% else %>
              <p class="text-sm text-base-content/60">No unfinished jobs are currently recorded.</p>
            <% end %>
          </div>
        </div>

        <div>
          <h3 class="font-medium mb-2">Recent Failures</h3>
          <% if @queue_status[:recent_failures].any? %>
            <div class="overflow-x-auto">
              <table class="table table-sm">
                <thead>
                  <tr>
                    <th>Job</th>
                    <th>Queue</th>
                    <th>Failed At</th>
                    <th>Error</th>
                  </tr>
                </thead>
                <tbody>
                  <% @queue_status[:recent_failures].each do |failure| %>
                    <tr>
                      <td><%= failure[:class_name] %></td>
                      <td><%= failure[:queue_name] %></td>
                      <td><%= local_time(failure[:failed_at], "%Y-%m-%d %H:%M:%S") %></td>
                      <td class="max-w-md truncate"><%= failure[:error] %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <p class="text-sm text-base-content/60">No recent failed executions were found.</p>
          <% end %>
        </div>
      <% else %>
        <div role="alert" class="alert alert-warning shadow-sm">
          <span><%= @queue_status[:message] %></span>
        </div>
      <% end %>
    </div>
  </div>

  <div class="card bg-base-100 border border-base-300 shadow-sm">
    <div class="card-body space-y-5">
      <h2 class="card-title text-lg">Images</h2>

      <%= form_with url: settings_path, method: :patch, local: true, class: "space-y-6" do |form| %>
        <div class="space-y-5">
          <h3 class="font-medium">Image Classification</h3>

          <div class="form-control">
            <label class="grid w-full cursor-pointer grid-cols-[auto,minmax(0,1fr)] items-start gap-4">
              <input type="checkbox" name="settings[image_classification_enabled]" value="1"
                     class="toggle toggle-primary mt-1 shrink-0"
                     <%= "checked" if @classification_enabled %>>
              <div class="min-w-0 w-full">
                <span class="block text-sm font-medium leading-5 text-base-content">Automatically classify newly uploaded images</span>
                <p class="mb-3 mt-0.5 whitespace-normal break-words text-xs leading-5 text-base-content/60">When enabled, each new tagscan photo is sent to CodeProject.AI after upload and the resulting people, vehicle, and animal detections are stored.</p>
              </div>
            </label>
          </div>

          <div class="grid gap-5 md:grid-cols-2">
            <div class="form-control">
              <%= form.label :image_classification_endpoint, "CodeProject.AI URL", class: "mb-1 block text-sm font-medium text-base-content" %>
              <%= form.text_field :image_classification_endpoint,
                  name: "settings[image_classification_endpoint]",
                  value: @classification_endpoint,
                  placeholder: "http://codeproject-host:32168",
                  class: "input input-bordered w-full" %>
              <p class="mb-3 mt-2 text-xs leading-5 text-base-content/60">Use the base server URL. The app will call <span class="font-mono">/v1/vision/detection</span>.</p>
            </div>

            <div class="form-control max-w-xs">
              <%= form.label :image_classification_min_confidence, "Minimum classification confidence", class: "mb-1 block text-sm font-medium text-base-content" %>
              <%= form.number_field :image_classification_min_confidence,
                  name: "settings[image_classification_min_confidence]",
                  value: @classification_min_confidence,
                  min: 0,
                  max: 1,
                  step: 0.05,
                  class: "input input-bordered w-full" %>
              <p class="mt-2 text-xs leading-5 text-base-content/60">Predictions below this threshold are filtered out before results are stored.</p>
            </div>
          </div>
        </div>

        <div class="divider"></div>

        <div class="space-y-5">
          <h3 class="font-medium">Image Purge</h3>

          <div class="form-control">
            <label class="grid w-full cursor-pointer grid-cols-[auto,minmax(0,1fr)] items-start gap-4">
              <input type="checkbox" name="settings[image_purge_enabled]" value="1"
                     class="toggle toggle-primary mt-1 shrink-0"
                     <%= "checked" if @purge_enabled %>>
              <div class="min-w-0 w-full">
                <span class="block text-sm font-medium leading-5 text-base-content">Enable automatic scheduled purge</span>
                <p class="mb-3 mt-0.5 whitespace-normal break-words text-xs leading-5 text-base-content/60">When enabled, images are purged daily at 2:00 AM according to the retention period below.</p>
              </div>
            </label>
          </div>

          <div class="form-control max-w-xs">
            <%= form.label :image_retention_days, "Retain images for (days)", class: "mb-1 block text-sm font-medium text-base-content" %>
            <%= form.number_field :image_retention_days,
                name: "settings[image_retention_days]",
                value: @retention_days,
                min: 1,
                step: 1,
                class: "input input-bordered w-full" %>
            <p class="mt-2 text-xs leading-5 text-base-content/60">Images attached to scans older than this many days will be eligible for purging.</p>
          </div>

          <div class="form-control">
            <label class="grid w-full cursor-pointer grid-cols-[auto,minmax(0,1fr)] items-start gap-4">
              <input type="checkbox" name="settings[image_purge_without_relevant_detections_enabled]" value="1"
                     class="toggle toggle-primary mt-1 shrink-0"
                     <%= "checked" if @purge_without_relevant_detections_enabled %>>
              <div class="min-w-0 w-full">
                <span class="block text-sm font-medium leading-5 text-base-content">Only purge images with no relevant detection</span>
                <p class="mb-3 mt-0.5 whitespace-normal break-words text-xs leading-5 text-base-content/60">Disabled by default. When enabled, an image must be classified and have no person, vehicle, or animal detection at or above the configured confidence before it is eligible for purge.</p>
              </div>
            </label>
          </div>

          <div class="form-control max-w-xs">
            <%= form.label :image_purge_without_relevant_detections_min_confidence, "Purge relevance confidence", class: "mb-1 block text-sm font-medium text-base-content" %>
            <%= form.number_field :image_purge_without_relevant_detections_min_confidence,
                name: "settings[image_purge_without_relevant_detections_min_confidence]",
                value: @purge_without_relevant_detections_min_confidence,
                min: 0,
                max: 1,
                step: 0.05,
                class: "input input-bordered w-full" %>
            <p class="mt-2 text-xs leading-5 text-base-content/60">A relevant detection meeting or exceeding this confidence protects the image from automatic purge.</p>
          </div>
        </div>

        <div>
          <%= form.submit "Save Settings", class: "btn btn-primary btn-sm" %>
        </div>
      <% end %>

      <div class="divider"></div>

      <div>
        <h3 class="font-medium mb-1">Image Classification Jobs</h3>
        <p class="text-sm text-base-content/60 mb-3">Queue background classification for existing photos. Use unclassified backfill first; full reclassification is available if you want to rerun everything after changing confidence thresholds or models.</p>
        <div class="flex flex-wrap gap-2">
          <%= button_to "Classify Unclassified Images",
              classify_unclassified_images_settings_path,
              method: :post,
              class: "btn btn-secondary btn-sm" %>
          <%= button_to "Reclassify All Images",
              reclassify_images_settings_path,
              method: :post,
              class: "btn btn-outline btn-sm",
              data: {
                turbo_confirm: "This will enqueue classification for every attached image, including already classified scans. Continue?"
              } %>
        </div>
      </div>

      <div class="divider"></div>

      <div>
        <h3 class="font-medium mb-1">Manual Purge</h3>
        <p class="text-sm text-base-content/60 mb-3">Immediately enqueue a purge using the current retention period above. This runs regardless of whether automatic purging is enabled.</p>
        <%= button_to "Purge Images Now",
            purge_images_settings_path,
            method: :post,
            class: "btn btn-warning btn-sm",
            data: {
              turbo_confirm: "This will permanently delete all unprotected images from scans older than #{@retention_days} day(s). This cannot be undone. Continue?"
            } %>
      </div>
    </div>
  </div>
</div>
