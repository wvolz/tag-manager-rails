<div class="card bg-base-100 shadow-sm border border-base-200">
  <div class="card-body">
    <h2 class="card-title mb-4"><%= title %></h2>

    <% if model.errors.any? %>
      <div class="alert alert-error shadow-sm mb-4" role="alert">
        <ul class="list-disc list-inside text-sm space-y-1">
          <% model.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="space-y-4">
      <%= yield %>
    </div>

    <div class="card-actions justify-between mt-6 pt-4 border-t border-base-200">
      <%= link_to "← Back", back_path, class: "btn btn-ghost btn-sm" %>
      <%= form.submit submit_label, class: "btn btn-primary btn-sm" %>
    </div>
  </div>
</div>
