<% content_for :title, "Tag Types" %>

<div class="flex items-center justify-between mb-4">
  <h1 class="text-2xl font-bold">Tag Types</h1>
  <%= link_to "New Tag Type", new_tag_type_path, class: "btn btn-primary btn-sm" %>
</div>

<% if @tag_types.empty? %>
  <div class="flex flex-col items-center justify-center py-16 text-center text-base-content/50">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 10h16M4 14h16M4 18h16" /></svg>
    <p class="font-medium">No tag types defined</p>
    <p class="text-sm mt-1">Tag types let you categorize and decode RFID tags by format.</p>
  </div>
<% else %>
  <div class="overflow-x-auto">
    <table class="table table-zebra w-auto">
      <thead>
        <tr>
          <th>Name</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @tag_types.each do |tag_type| %>
          <tr class="hover:bg-base-200">
            <td class="font-medium">
              <%= link_to tag_type.name, tag_type_path(tag_type), class: "link link-primary" %>
            </td>
            <td>
              <div class="flex gap-1">
                <%= link_to "Edit", edit_tag_type_path(tag_type), class: "btn btn-xs btn-outline" %>
                <%= link_to "Delete", tag_type_path(tag_type), data: { turbo_method: :delete, turbo_confirm: "Delete this tag type?" }, class: "btn btn-xs btn-error btn-outline" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
