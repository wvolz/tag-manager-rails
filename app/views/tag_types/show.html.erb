<% content_for :title, @tag_type.name %>

<%= render "shared/show_header",
    title: @tag_type.name,
    subtitle: "Tag Type",
    back_path: tag_types_path %>

<div class="max-w-xl">
  <div class="card bg-base-100 shadow-sm border border-base-200">
    <div class="card-body">
      <table class="table table-sm">
        <tbody>
          <tr>
            <th class="w-32 text-base-content/60 font-medium">Name</th>
            <td><%= @tag_type.name %></td>
          </tr>
          <tr>
            <th class="text-base-content/60 font-medium">Decoder</th>
            <td>
              <% if @tag_type.decoder.present? %>
                <span class="badge badge-outline"><%= @tag_type.decoder %></span>
              <% else %>
                —
              <% end %>
            </td>
          </tr>
          <tr>
            <th class="text-base-content/60 font-medium">Created</th>
            <td><time datetime="<%= @tag_type.created_at.iso8601 %>"><%= @tag_type.created_at.strftime("%b %d, %Y") %></time></td>
          </tr>
        </tbody>
      </table>

      <div class="card-actions justify-end mt-4">
        <%= link_to "Edit", edit_tag_type_path(@tag_type), class: "btn btn-outline btn-sm" %>
        <%= link_to "Delete", tag_type_path(@tag_type),
            data: { turbo_method: :delete, turbo_confirm: "Delete this tag type?" },
            class: "btn btn-error btn-outline btn-sm" %>
      </div>
    </div>
  </div>
</div>

</div>
