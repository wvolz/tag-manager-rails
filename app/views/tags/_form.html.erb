<%= form_with(model: tag, local: true) do |form| %>
  <% render "shared/form_card",
      title: tag.new_record? ? "New Tag" : "Edit Tag",
      model: tag,
      form: form,
      back_path: tags_path,
      submit_label: tag.new_record? ? "Create Tag" : "Update Tag" do %>

    <div class="form-control">
      <%= form.label :tag_type_id, "Tag Type", class: "label" %>
      <%= form.collection_select :tag_type_id, TagType.order(:name), :id, :name,
          { include_blank: "Select a tag type..." },
            { class: "select select-bordered w-full", required: true } %>
    </div>

    <div class="form-control">
      <%= form.label :epc, "EPC", class: "label" %>
      <%= form.text_field :epc, id: :tag_epc,
            class: "input input-bordered w-full font-mono text-sm",
            placeholder: "3009A6000000000000000123" %>
    </div>

    <div class="form-control">
      <%= form.label :tid, "TID", class: "label" %>
      <%= form.text_field :tid, id: :tag_tid,
            class: "input input-bordered w-full font-mono text-sm",
            placeholder: "E2001058000000020000" %>
    </div>

    <div class="form-control">
      <%= form.label :pc, "PC", class: "label" %>
      <%= form.text_field :pc, id: :tag_pc,
            class: "input input-bordered w-full font-mono text-sm",
            placeholder: "3000" %>
    </div>

    <div class="form-control">
      <%= form.label :description, "Description", class: "label" %>
      <%= form.text_field :description, id: :tag_description,
            class: "input input-bordered w-full",
            placeholder: "e.g. Warehouse Item A" %>
    </div>

    <div class="form-control">
      <%= form.label :user_memory, "User Memory", class: "label" %>
      <%= form.text_field :user_memory, id: :tag_user_memory,
            class: "input input-bordered w-full font-mono text-sm",
            placeholder: "000102030405" %>
    </div>

    <fieldset class="fieldset bg-base-100 border border-base-300 rounded-box p-4">
      <legend class="fieldset-legend text-sm font-medium">Authorizations</legend>
      <div class="flex flex-col gap-2">
        <% if Authorization.exists? %>
          <%= form.collection_check_boxes :authorization_ids, Authorization.order(:name), :id, :name do |b| %>
            <label class="flex items-center gap-2 cursor-pointer">
              <%= b.check_box(class: "checkbox checkbox-sm") %>
              <span class="text-sm"><%= b.text %></span>
            </label>
          <% end %>
        <% else %>
          <p class="text-xs text-base-content/50 italic">No authorizations created yet.</p>
        <% end %>
      </div>
    </fieldset>

  <% end %>
<% end %>
