<%= form_with(model: tag, local: true, class: "w-full max-w-md") do |form| %>
  <% if tag.errors.any? %>
    <div class="alert alert-error shadow-sm mb-4">
      <ul class="list-disc list-inside text-sm">
        <% tag.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-control mb-3">
    <%= form.label :tag_type, class: "label" %>
    <%= form.collection_select :tag_type_id, TagType.order(:name), :id, :name,
          { include_blank: "— select —" },
          { class: "select select-bordered w-full" } %>
  </div>

  <div class="form-control mb-3">
    <%= form.label :epc, "EPC", class: "label" %>
    <%= form.text_field :epc, id: :tag_epc, class: "input input-bordered w-full font-mono" %>
  </div>

  <div class="form-control mb-3">
    <%= form.label :tid, "TID", class: "label" %>
    <%= form.text_field :tid, id: :tag_tid, class: "input input-bordered w-full font-mono" %>
  </div>

  <div class="form-control mb-3">
    <%= form.label :user_memory, "User Memory", class: "label" %>
    <%= form.text_field :user_memory, id: :tag_user_memory, class: "input input-bordered w-full font-mono" %>
  </div>

  <div class="form-control mb-3">
    <%= form.label :description, class: "label" %>
    <%= form.text_field :description, id: :tag_description, class: "input input-bordered w-full" %>
  </div>

  <div class="form-control mb-3">
    <%= form.label :pc, "PC", class: "label" %>
    <%= form.text_field :pc, id: :tag_pc, class: "input input-bordered w-full font-mono" %>
  </div>

  <div class="form-control mb-4">
    <fieldset class="fieldset bg-base-100 border border-base-300 rounded-box p-4">
      <legend class="fieldset-legend text-sm font-medium">Authorizations</legend>
      <div class="flex flex-col gap-1 mt-1">
        <%= form.collection_check_boxes :authorization_ids, Authorization.order(:name), :id, :name do |b| %>
          <label class="flex items-center gap-2 cursor-pointer">
            <%= b.check_box(class: "checkbox checkbox-sm") %>
            <span class="text-sm"><%= b.text %></span>
          </label>
        <% end %>
      </div>
    </fieldset>
  </div>

  <div class="mt-4">
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
