<% tag = local_assigns.fetch(:tag, @tag) %>

<table class="table table-sm table-bordered">
  <thead>
    <tr>
      <th>Header</th>
      <th>Filter</th>
      <th>Partition</th>
      <th>Company Prefix</th>
      <th>Item Reference</th>
      <th>Serial</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td><%= tag.uii_decode.header %></td>
      <td><%= tag.uii_decode.filter %> (<%= tag.uii_decode.filter_name %>)</td>
      <td><%= tag.uii_decode.partition %> (<%= tag.uii_decode.partition_layout %>)</td>
      <td>
        <div class="space-y-1">
          <div><%= tag.uii_decode.company_prefix %></div>
          <% if tag.uii_decode.company_name.present? %>
            <div class="text-xs text-base-content/70">Company: <%= tag.uii_decode.company_name %></div>
          <% end %>
        </div>
      </td>
      <td><%= tag.uii_decode.item_reference %></td>
      <td><%= tag.uii_decode.serial %></td>
    </tr>
  </tbody>
</table>

<% if tag.uii_decode.company_name.present? %>
  <p class="text-sm text-base-content/80 mt-2">
    <strong>Company name:</strong> <%= tag.uii_decode.company_name %>
  </p>
<% end %>

<p class="text-xs text-base-content/70 mt-2">
  The numeric company prefix is decoded from the EPC. When a local mapping exists, the company name above is resolved from the Company Prefix Maps table; otherwise the raw prefix is still shown for manual lookup.
</p>
