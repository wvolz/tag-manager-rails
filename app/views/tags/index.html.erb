<% content_for :title, "Tags" %>

<div class="flex items-center justify-between mb-4">
  <div>
    <h1 class="text-2xl font-bold">Tags</h1>
    <% if @pagy.count > 0 %>
      <p class="text-sm text-base-content/60 mt-0.5"><%== pagy_info(@pagy) %></p>
    <% end %>
  </div>
  <%= link_to "New Tag", new_tag_path, class: "btn btn-primary btn-sm" %>
</div>

<% if @pagy.count.zero? %>
  <div class="flex flex-col items-center justify-center py-16 text-center text-base-content/50">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z" /></svg>
    <p class="font-medium">No tags yet</p>
    <p class="text-sm mt-1">Get started by <%= link_to "creating your first tag", new_tag_path, class: "link" %>.</p>
  </div>
<% else %>
  <div class="w-full overflow-x-auto">
    <table class="table table-zebra min-w-full">
      <thead>
        <tr>
          <th class="whitespace-nowrap">EPC</th>
          <th>Description</th>
          <th class="max-lg:hidden whitespace-nowrap">PC</th>
          <th class="max-md:hidden">Type</th>
          <th class="whitespace-nowrap"><%= sortable "created_at", "Date Added" %></th>
          <th class="max-lg:hidden whitespace-nowrap"><%= sortable "updated_at", "Updated" %></th>
          <th class="max-md:hidden whitespace-nowrap">Last Seen</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @tags.each do |tag| %>
          <% next unless tag.id.present? %>
          <tr class="hover:bg-base-200">
            <td class="font-mono text-xs">
              <%= link_to tag.epc, tag_path(tag), class: "link link-primary" %>
            </td>
            <td class="max-w-44 truncate"><%= tag.description.presence || "—" %></td>
            <td class="max-lg:hidden font-mono text-xs"><%= tag.pc.presence || "—" %></td>
            <td class="max-md:hidden"><%= tag.tag_type&.name || "—" %></td>
            <td class="text-sm whitespace-nowrap"><%= local_time(tag.created_at) if tag.created_at %></td>
            <td class="max-lg:hidden text-sm whitespace-nowrap"><%= local_time(tag.updated_at) if tag.updated_at %></td>
            <td class="max-md:hidden text-sm whitespace-nowrap"><%= local_time(tag.last_seen_at) if tag.last_seen_at %></td>
            <td>
              <div class="flex gap-1">
                <%= link_to "Edit", edit_tag_path(tag), class: "btn btn-xs btn-outline" %>
                <%= link_to "Delete", tag_path(tag), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this tag?" }, class: "btn btn-xs btn-error btn-outline" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="flex justify-center mt-4">
    <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
  </div>
<% end %>
