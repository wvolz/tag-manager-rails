<%= form_with(model: tagscan, local: true, class: "w-full max-w-md") do |form| %>
  <% if tagscan.errors.any? %>
    <div class="alert alert-error shadow-sm mb-4">
      <ul class="list-disc list-inside text-sm">
        <% tagscan.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-control mb-3">
    <%= form.label :tag_epc, "EPC", class: "label" %>
    <%= form.text_field :tag_epc, class: "input input-bordered w-full font-mono" %>
  </div>

  <div class="form-control mb-3">
    <%= form.label :tag_pc, "PC", class: "label" %>
    <%= form.text_field :tag_pc, class: "input input-bordered w-full font-mono" %>
  </div>

  <div class="form-control mb-3">
    <%= form.label :antenna, class: "label" %>
    <%= form.text_field :antenna, id: :tagscan_antenna, class: "input input-bordered w-full" %>
  </div>

  <div class="form-control mb-3">
    <%= form.label :rssi, "RSSI", class: "label" %>
    <%= form.text_field :rssi, id: :tagscan_rssi, class: "input input-bordered w-full" %>
  </div>

  <div class="mt-4">
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
