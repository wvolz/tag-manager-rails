<% content_for :title, "Tag Scans" %>

<div class="flex items-center justify-between mb-4">
  <div>
    <h1 class="text-2xl font-bold">Tag Scans</h1>
    <% if @pagy.count > 0 %>
      <p class="text-sm text-base-content/60 mt-0.5"><%== pagy_info(@pagy) %></p>
    <% end %>
  </div>
  <%= link_to "New Scan", new_tagscan_path, class: "btn btn-primary btn-sm" %>
</div>

<% if @tagscans.empty? %>
  <div class="flex flex-col items-center justify-center py-16 text-center text-base-content/50">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
    <p class="font-medium">No tag scans yet</p>
    <p class="text-sm mt-1">Scans submitted by readers will appear here.</p>
  </div>
<% else %>
  <div class="overflow-x-auto">
    <table class="table table-zebra">
      <thead>
        <tr>
          <th>Date</th>
          <th>EPC</th>
          <th>PC</th>
          <th>Antenna</th>
          <th>RSSI</th>
          <th>Image</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @tagscans.each do |tagscan| %>
          <tr class="hover:bg-base-200">
            <td class="text-sm">
              <%= link_to tagscan_path(tagscan), class: "link link-primary" do %>
                <%= local_time(tagscan.created_at) %>
              <% end %>
            </td>
            <% if tagscan.tag %>
              <td class="font-mono text-xs"><%= tagscan.tag.epc %></td>
              <td class="font-mono text-xs"><%= tagscan.tag.pc %></td>
            <% else %>
              <td class="text-base-content/40">—</td>
              <td class="text-base-content/40">—</td>
            <% end %>
            <td><%= tagscan.antenna %></td>
            <td><%= tagscan.rssi %></td>
            <td>
              <% if tagscan.image.attached? %>
                <%= link_to(image_tag(tagscan.image.variant(resize_to_limit: [60, 60]), class: "rounded"), url_for(tagscan.image)) %>
              <% else %>
                <%= image_tag "no-image-graphic.png", class: "h-10 w-10 opacity-30" %>
              <% end %>
            </td>
            <td>
              <div class="flex gap-1">
                <%= link_to "Edit", edit_tagscan_path(tagscan), class: "btn btn-xs btn-outline" %>
                <%= link_to "Delete", tagscan_path(tagscan), data: { turbo_method: :delete, turbo_confirm: "Delete this scan?" }, class: "btn btn-xs btn-error btn-outline" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="flex justify-center mt-4">
    <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
  </div>
<% end %>
