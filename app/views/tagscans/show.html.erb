<% content_for :title, "Tag Scan ##{@tagscan.id}" %>

<div class="max-w-4xl space-y-5">
    <div class="flex items-start justify-between gap-3">
        <div>
            <h1 class="text-2xl font-bold">Tag Scan #<%= @tagscan.id %></h1>
            <p class="text-sm text-base-content/60 mt-1">
                <time datetime="<%= @tagscan.received_at.iso8601 %>"><%= @tagscan.received_at.strftime("%b %d, %Y at %H:%M:%S") %></time>
            </p>
        </div>
        <div class="flex items-center gap-2">
            <%= link_to "Edit", edit_tagscan_path(@tagscan), class: "btn btn-outline btn-sm" %>
            <%= link_to "Delete", tagscan_path(@tagscan), data: { turbo_method: :delete, turbo_confirm: "Delete this scan?" }, class: "btn btn-error btn-outline btn-sm" %>
            <%= link_to "Back", tagscans_path, class: "btn btn-ghost btn-sm" %>
        </div>
    </div>

    <div class="card bg-base-100 border border-base-300 shadow-sm">
        <div class="card-body gap-5">
            <%# ── Scan details ─────────────────────────────── %>
            <div class="overflow-x-auto">
                <table class="table table-sm">
                    <tbody>
                        <tr>
                            <th class="w-36 text-base-content/60 font-medium">Scan time</th>
                            <td><time datetime="<%= @tagscan.received_at.iso8601 %>"><%= @tagscan.received_at.strftime("%b %d, %Y at %H:%M:%S") %></time></td>
                        </tr>
                        <tr>
                            <th class="text-base-content/60 font-medium">Inserted at</th>
                            <td><time datetime="<%= @tagscan.created_at.iso8601 %>"><%= @tagscan.created_at.strftime("%b %d, %Y at %H:%M:%S") %></time></td>
                        </tr>
                        <tr>
                            <th class="w-36 text-base-content/60 font-medium">Antenna</th>
                            <td><%= @tagscan.antenna.presence || "—" %></td>
                        </tr>
                        <tr>
                            <th class="text-base-content/60 font-medium">RSSI</th>
                            <td><%= @tagscan.rssi.presence || "—" %></td>
                        </tr>
                        <% if @tagscan.event_id.present? %>
                        <tr>
                            <th class="text-base-content/60 font-medium">Event ID</th>
                            <td><code class="text-xs bg-base-200 px-2 py-0.5 rounded"><%= @tagscan.event_id %></code></td>
                        </tr>
                        <% end %>
                        <tr>
                            <th class="text-base-content/60 font-medium">Tag</th>
                            <td>
                                <% if @tagscan.tag %>
                                    <%= link_to(@tagscan.tag.epc.presence || "Tag ##{@tagscan.tag.id}", tag_path(@tagscan.tag), class: "link link-primary font-mono text-xs break-all") %>
                                    <span class="ml-2 text-xs text-base-content/50">
                                        [<%= @tagscan.tag.description.presence || "Tag ##{@tagscan.tag.id}" %>]
                                    </span>
                                <% else %>
                                    <span class="text-base-content/40">No linked tag</span>
                                <% end %>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <%# ── Snapshot ─────────────────────────────────── %>
            <% if @tagscan.image.attached? %>
                <div>
                    <div class="flex items-center gap-3 mb-2">
                        <h2 class="text-sm font-semibold text-base-content/60">Snapshot</h2>
                        <%= button_to @tagscan.image_protected? ? "Protected" : "Protect Image",
                            tagscan_path(@tagscan),
                            method: :patch,
                            params: { tagscan: { image_protected: !@tagscan.image_protected? } },
                            class: "btn btn-xs #{@tagscan.image_protected? ? 'btn-success' : 'btn-ghost btn-outline'}" %>
                    </div>
                    <%= link_to url_for(@tagscan.image), target: "_blank", rel: "noopener", class: "block max-w-md" do %>
                        <%= image_tag @tagscan.image.variant(resize_to_limit: [480, 480]), class: "w-full rounded border border-base-300", alt: "Scan snapshot for tag scan #{@tagscan.id}" %>
                    <% end %>
                    <p class="text-xs text-base-content/60 mt-1">Click to open full size.</p>
                </div>
            <% end %>
        </div>
    </div>
</div>
