<%= form_with(model: user, local: true) do |form| %>
  <% render "shared/form_card",
      title: user.new_record? ? "New User" : "Edit User",
      model: user,
      form: form,
      back_path: users_path,
      submit_label: user.new_record? ? "Create User" : "Update User" do %>

    <div class="grid grid-cols-2 gap-4">
      <div class="form-control">
        <%= form.label :first_name, "First Name", class: "label" %>
        <%= form.text_field :first_name,
              class: "input input-bordered w-full",
              placeholder: "John" %>
      </div>

      <div class="form-control">
        <%= form.label :last_name, "Last Name", class: "label" %>
        <%= form.text_field :last_name,
              class: "input input-bordered w-full",
              placeholder: "Doe" %>
      </div>
    </div>

    <div class="form-control">
      <%= form.label :email, "Email", class: "label" %>
      <%= form.email_field :email,
            class: "input input-bordered w-full",
            placeholder: "user@example.com",
            required: true %>
    </div>

    <div class="form-control">
      <%= form.label :password, "Password", class: "label" %>
      <% unless user.new_record? %>
        <p class="label-text-alt text-base-content/60 mb-1">Leave blank to keep current password</p>
      <% end %>
      <%= form.password_field :password,
            class: "input input-bordered w-full",
            required: user.new_record? %>
    </div>

    <div class="form-control">
      <%= form.label :password_confirmation, "Confirm Password", class: "label" %>
      <%= form.password_field :password_confirmation,
            class: "input input-bordered w-full",
            required: user.new_record? %>
    </div>

    <% if current_user.admin? %>
      <div class="form-control">
        <label class="label cursor-pointer justify-start gap-3 pb-0">
          <%= form.check_box :admin, class: "checkbox checkbox-primary" %>
          <span class="label-text font-medium">Administrator</span>
        </label>
      </div>
    <% end %>

  <% end %>
<% end %>
